# GEMINI_API_KEY: Required for Gemini AI API calls.
# Keep this in Vercel Environment Variables or .env.local for `vercel dev`.
# It is never injected into the browser bundle.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Optional. Defaults to gemini-3-flash-preview.
GEMINI_MODEL="gemini-3-flash-preview"

# Redis storage for shared invoices. Vercel Redis/Upstash provides these.
UPSTASH_REDIS_REST_URL="MY_UPSTASH_REDIS_REST_URL"
UPSTASH_REDIS_REST_TOKEN="MY_UPSTASH_REDIS_REST_TOKEN"

# Also supported when Vercel exposes KV-style names:
# KV_REST_API_URL="MY_KV_REST_API_URL"
# KV_REST_API_TOKEN="MY_KV_REST_API_TOKEN"

# Required for temporary encrypted SRI login sessions.
# Use a long random value and keep it only in Vercel Environment Variables.
SRI_SESSION_SECRET="MY_RANDOM_SECRET"
